{
  "name": "temp-workspace",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/temp-workspace/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/temp-workspace/test/jest-e2e.json",
    "start:infra": "docker-compose up -d",
    "start:api": "nest start api-gateway --watch",
    "start:auth": "nest start auth-service --watch",
    "start:user": "nest start user-service --watch",
    "start:book": "nest start book-service --watch",
    "start:order": "nest start order-service --watch",
    "start:review": "nest start review-service --watch",
    "start:search": "nest start search-service --watch",
    "start:all": "npm run start:infra && concurrently -c \"magenta,cyan,blue,yellow,green,red,white\" -n \"GATEWAY,AUTH,USER,BOOK,ORDER,REVIEW,SEARCH\" \"npm run start:api\" \"npm run start:auth\" \"npm run start:user\" \"npm run start:book\" \"npm run start:order\" \"npm run start:review\" \"npm run start:search\"",
    "build:all": "nest build api-gateway && nest build auth-service && nest build user-service && nest build book-service && nest build order-service && nest build review-service && nest build search-service",
    "start:api:dist": "node dist/apps/api-gateway/main",
    "start:auth:dist": "node dist/apps/auth-service/main",
    "start:user:dist": "node dist/apps/user-service/main",
    "start:book:dist": "node dist/apps/book-service/main",
    "start:order:dist": "node dist/apps/order-service/main",
    "start:review:dist": "node dist/apps/review-service/main",
    "start:search:dist": "node dist/apps/search-service/main",
    "start:all:dist": "npm run start:infra && concurrently -c \"magenta,cyan,blue,yellow,green,red,white\" -n \"GATEWAY,AUTH,USER,BOOK,ORDER,REVIEW,SEARCH\" \"npm run start:api:dist\" \"npm run start:auth:dist\" \"npm run start:user:dist\" \"npm run start:book:dist\" \"npm run start:order:dist\" \"npm run start:review:dist\" \"npm run start:search:dist\""
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.4.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.27",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/typeorm": "^11.0.3",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^2.0.1",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/contracts(|/.*)$": "<rootDir>/libs/contracts/src/$1"
    }
  }
}
